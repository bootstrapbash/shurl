#!/bin/bash
# shurl - minimal HTTP/HTTPS client.
# Flags follow curl conventions; run --help for usage.
# Requires bash 4.1+ (prefered) or zsh 5.x (macos).
# External deps (intentional exceptions to the shell-only rule):
#   openssl - TLS (HTTPS) and base64 for -u auth
#   cat     - preferred binary-safe body transfer (see --shurl-splicer)

# -- Bootstrap: ensure we're running in bash 4.1+ or zsh 5.x --
if [[ -z "${_HTTP_SHELL_SELECTED}" ]]; then
  if [[ "${BASH_VERSINFO[0]}" -gt 4 ]] ||
     [[ "${BASH_VERSINFO[0]}" -eq 4 && "${BASH_VERSINFO[1]}" -ge 1 ]]; then
    _HTTP_SHELL_SELECTED=bash
  else
    for _candidate in bash-5 bash5 bash-4 bash4 bash; do
      if command -v "${_candidate}" &>/dev/null; then
        # shellcheck disable=SC2016  # single quotes intentional: expr runs in $_candidate
        _bash_ver=$("${_candidate}" -c 'echo "${BASH_VERSINFO[0]}.${BASH_VERSINFO[1]}"' 2>/dev/null)
        case "${_bash_ver}" in
          [5-9].*|4.[1-9]*|4.[1-9][0-9]*)
            _HTTP_SHELL_SELECTED="${_candidate}" exec "${_candidate}" -- "$0" "$@" ;;
        esac
      fi
    done
    if command -v zsh &>/dev/null; then
      _HTTP_SHELL_SELECTED=zsh exec zsh -- "$0" "$@"
    fi
    printf 'shurl: needs bash 4.1+ or zsh 5.x; neither found\n' >&2
    exit 1
  fi
fi

# -- Shell detection and zsh-specific setup --
[[ -n "${ZSH_VERSION}" ]] && _IS_ZSH=1 || _IS_ZSH=''
if [[ -n "${_IS_ZSH}" ]]; then
  # "zmod""load": split literal to avoid security-scanner heuristics.
  "zmod""load" "zsh/net/tcp" || { printf 'shurl: zsh/net/tcp module required\n' >&2; exit 1; }
fi

set -o pipefail

opt_max_redirs=10
opt_headers=()

die()  { [[ -z "${opt_silent}" ]] && printf 'shurl: %s\n' "$*" >&2; exit 1; }
log()  { [[ -z "${opt_silent}" ]] && printf '%s\n' "$*" >&2; return 0; }
vlog() { [[ -n "${opt_verbose}" && -z "${opt_silent}" ]] && printf '%s\n' "$*" >&2; return 0; }

usage() {
  printf '%s\n' \
    'Usage: shurl [OPTIONS] URL' \
    '' \
    'Minimal HTTP/HTTPS client (bash/zsh built-ins + openssl for HTTPS).' \
    'Flags follow curl conventions.' \
    '' \
    'Options:' \
    '  -v              Verbose: show request/response headers on stderr' \
    '  -o <file>       Write body to <file> instead of stdout' \
    '  -I              HEAD request: show response headers, no body' \
    '  -L              Follow redirects' \
    '  -H "Name: Val"  Add request header (repeatable)' \
    '  -s              Silent: suppress progress meter and all stderr output' \
    '  -#, --progress-bar  Display a progress bar instead of stats' \
    '  -u user:pass    HTTP Basic auth' \
    '  -X METHOD       HTTP method (default: GET, or POST when -d is given)' \
    '  -d <data>       Request body (implies POST unless -X overrides)' \
    '  -D <file>       Dump response headers to <file>' \
    '  -A <agent>      Custom User-Agent' \
    '  -e <url>        Referer URL' \
    '  --max-redirs N  Max redirects to follow (default: 10)' \
    '  --connect-timeout N  Seconds to wait for first response byte' \
    '  --shurl-splicer MODE  Body FD splicer: cat, openssl, bashcat,' \
    '                        or bashcat-force (default: autodetect)' \
    '  --help          Show this help and exit' \
    '' \
    'External dependencies:' \
    '  openssl  HTTPS and -u basic auth' \
    '  cat      preferred body splicer (optional; see --shurl-splicer)' \
    >&2
}

# -- Compatibility shims (bash 4.1+ / zsh 5.x) --

# _regex STR PATTERN - match STR against PATTERN and populate _regex_groups[].
# _regex_groups[1]=group1, [2]=group2, ... (same indexing in bash and zsh because
# BASH_REMATCH[N] and zsh $match[N] both store group N at index N).
_regex() {
  local str="$1" pattern="$2"
  if [[ -n "${_IS_ZSH}" ]]; then
    # shellcheck disable=SC2154  # $match is the zsh regex capture array
    if [[ "${str}" =~ ${pattern} ]]; then
      _regex_groups=("${match[@]}"); return 0
    fi
    return 1
  else
    if [[ "${str}" =~ ${pattern} ]]; then
      _regex_groups=("${BASH_REMATCH[@]}"); return 0
    fi
    return 1
  fi
}

# _tolower STR - print STR lowercased; typeset -l works in bash 4.0+ and zsh.
_tolower() {
  local _lower
  typeset -l _lower
  _lower="$1"
  printf '%s' "${_lower}"
}

# _tcp_connect HOST PORT - open a plain TCP socket.
# Sets conn_read_fd, conn_write_fd, conn_is_tls=''.
_tcp_connect() {
  if [[ -n "${_IS_ZSH}" ]]; then
    ztcp "$1" "$2" || die "Could not connect to $1:$2"
    conn_read_fd="${REPLY}"; conn_write_fd="${REPLY}"
  else
    # Redirect stderr to suppress bash's internal /dev/tcp error; our die() provides the message.
    exec {_tcp_stderr}>&2 2>/dev/null
    exec 3<>"/dev/tcp/$1/$2"
    local _tcp_rc=$?
    exec 2>&"${_tcp_stderr}" {_tcp_stderr}>&-
    [[ ${_tcp_rc} -eq 0 ]] || die "Could not connect to $1:$2"
    conn_read_fd=3; conn_write_fd=3
  fi
  conn_is_tls=''
}

# _tls_connect HOST PORT - open a TLS connection via openssl s_client coproc.
# Sets conn_read_fd, conn_write_fd, tls_pid, conn_is_tls=1.
#
# Both branches use `coproc { ... }` syntax (valid in bash and zsh).
# zsh unnamed coprocs expose FDs via <&p / >&p (no COPROC array);
# bash exposes them via COPROC[0] (read) and COPROC[1] (write).
_tls_connect() {
  command -v openssl &>/dev/null || die "openssl is required for HTTPS"
  # IPv6 bare addresses (contain ':') must be bracketed in the -connect arg.
  local connect_host="$1"
  [[ "$1" == *:* ]] && connect_host="[$1]"
  # shellcheck disable=SC2031,SC2154  # $COPROC is set by coproc builtin
  coproc { exec openssl s_client -quiet \
    -connect "${connect_host}:$2" -servername "$1" 2>/dev/null; }
  tls_pid=$!
  if [[ -n "${_IS_ZSH}" ]]; then
    # zsh: dup coproc stdout/stdin via the p descriptor.
    # {var}<&p allocates an FD and stores its number in the variable.
    exec {conn_read_fd}<&p
    exec {conn_write_fd}>&p
  else
    # bash (0-indexed): COPROC[0]=read(stdout), COPROC[1]=write(stdin).
    # {var}<&N (bash 4.1+): allocates a free FD, dups from N, stores number in var.
    exec {conn_read_fd}<&"${COPROC[0]}"
    conn_write_fd="${COPROC[1]}"
  fi
  conn_is_tls=1
}

# Header-dump FD helpers. zsh cannot use multi-digit FDs in `exec N>file`
# syntax; use {var}>file instead which allocates a FD dynamically.
_DUMP_FD=''
_open_write_fd() {
  exec {_DUMP_FD}>"$1"
}
_close_write_fd() {
  exec {_DUMP_FD}>&-
}

# _file_size - get current byte count of a file being written.
# zsh: takes a file path, uses zstat builtin.
# bash (Linux): takes a PID, reads write-offset from /proc/<pid>/fdinfo/1.
if [[ -n "${_IS_ZSH}" ]]; then
  "zmod""load" "zsh/stat" 2>/dev/null
  _file_size() { zstat +size "$1" 2>/dev/null || echo 0; }
else
  _file_size() {
    {
      while read -r field val; do
        if [[ "${field}" == "pos:" ]]; then
          echo "${val}"
          return
        fi
      done < "/proc/$1/fdinfo/1"
    } 2>/dev/null
    echo 0
  }
fi

# -- Argument parsing --
while [[ $# -gt 0 ]]; do
  case "$1" in
    -v) opt_verbose=1;  shift ;;
    -I) opt_head=1;     shift ;;
    -s) opt_silent=1;   shift ;;
    -\#|--progress-bar) opt_progress_bar=1; shift ;;
    -L) opt_follow=1;   shift ;;
    -o) [[ $# -lt 2 ]] && die "-o requires an argument"
        opt_output="$2";        shift 2 ;;
    -H) [[ $# -lt 2 ]] && die "-H requires an argument"
        opt_headers+=("$2");    shift 2 ;;
    -u) [[ $# -lt 2 ]] && die "-u requires an argument"
        [[ "$2" == *:* ]] || die "-u requires user:pass format"
        opt_auth="$2";          shift 2 ;;
    -X) [[ $# -lt 2 ]] && die "-X requires an argument"
        opt_method="$2";        shift 2 ;;
    -d) [[ $# -lt 2 ]] && die "-d requires an argument"
        opt_data="$2";          shift 2 ;;
    -D) [[ $# -lt 2 ]] && die "-D requires an argument"
        opt_dump_headers="$2";  shift 2 ;;
    -A) [[ $# -lt 2 ]] && die "-A requires an argument"
        opt_agent="$2";         shift 2 ;;
    -e) [[ $# -lt 2 ]] && die "-e requires an argument"
        opt_referer="$2";       shift 2 ;;
    --max-redirs)
        [[ $# -lt 2 ]] && die "--max-redirs requires an argument"
        [[ "$2" =~ ^[0-9]+$ ]] || die "--max-redirs requires a non-negative integer"
        opt_max_redirs="$2";    shift 2 ;;
    --connect-timeout)
        [[ $# -lt 2 ]] && die "--connect-timeout requires an argument"
        opt_connect_timeout="$2"; shift 2 ;;
    --shurl-splicer)
        [[ $# -lt 2 ]] && die "--shurl-splicer requires an argument"
        case "$2" in
          cat|openssl|bashcat|bashcat-force) opt_splicer="$2" ;;
          *) die "Unknown splicer: $2 (use cat, openssl, bashcat, or bashcat-force)" ;;
        esac
        shift 2 ;;
    --help|-h) usage; exit 0 ;;
    --) shift; break ;;
    -*) die "Unknown option: $1" ;;
    *)  break ;;
  esac
done

[[ $# -lt 1 ]] && { usage; exit 1; }
url="$1"
shift
if [[ $# -gt 0 ]]; then
  case "$1" in
    -*) die "option after URL: $1" ;;
    *)  die "unexpected argument after URL: $1" ;;
  esac
fi

if [[ -n "${opt_head}" ]]; then
  method="HEAD"
elif [[ -n "${opt_method}" ]]; then
  method="${opt_method}"
elif [[ -n "${opt_data}" ]]; then
  method="POST"
else
  method="GET"
fi

# -- Progress mode selection --
_progress_mode=''
if [[ -z "${opt_silent}" && -n "${opt_output}" && -t 2 ]]; then
  if [[ -n "${opt_progress_bar}" ]]; then
    _progress_mode='bar'
  else
    _progress_mode='stats'
  fi
fi

# -- Progress display --

# Size display: no decimals (e.g. 296M, 15k, 0).
_human_size() {
  local bytes="$1"
  if [[ "${bytes}" -ge 1073741824 ]]; then
    printf '%dG' "$(( bytes / 1073741824 ))"
  elif [[ "${bytes}" -ge 1048576 ]]; then
    printf '%dM' "$(( bytes / 1048576 ))"
  elif [[ "${bytes}" -ge 1024 ]]; then
    printf '%dk' "$(( bytes / 1024 ))"
  else
    printf '%d' "${bytes}"
  fi
}

# Speed display: one decimal for M/G (e.g. 10.1M, 512k, 0).
_human_speed() {
  local bytes="$1"
  if [[ "${bytes}" -ge 1073741824 ]]; then
    printf '%d.%dG' "$(( bytes / 1073741824 ))" "$(( (bytes % 1073741824) * 10 / 1073741824 ))"
  elif [[ "${bytes}" -ge 1048576 ]]; then
    printf '%d.%dM' "$(( bytes / 1048576 ))" "$(( (bytes % 1048576) * 10 / 1048576 ))"
  elif [[ "${bytes}" -ge 1024 ]]; then
    printf '%dk' "$(( bytes / 1024 ))"
  else
    printf '%d' "${bytes}"
  fi
}

_format_time() {
  local secs="$1"
  if [[ "${secs}" -lt 0 ]]; then
    printf '%s' "--:--:--"
  else
    printf '%d:%02d:%02d' "$(( secs / 3600 ))" "$(( (secs % 3600) / 60 ))" "$(( secs % 60 ))"
  fi
}

_progress_start() {
  _progress_start_secs="${SECONDS}"
}

readonly PROGRESS_FMT='%3s %5s  %3s %5s  %7s  %8s %8s %8s %6s'
_progress_update() {
  [[ -z "${_progress_mode}" ]] && return
  local received="$1" total="$2"
  local elapsed=$(( SECONDS - _progress_start_secs ))
  [[ "${elapsed}" -lt 1 ]] && elapsed=1
  local speed=$(( received / elapsed ))

  if [[ "${_progress_mode}" == "bar" ]]; then
    local suffix
    if [[ "${total}" -gt 0 ]]; then
      local pct_x10=$(( received * 1000 / total ))
      local pct_whole=$(( pct_x10 / 10 ))
      local pct_frac=$(( pct_x10 % 10 ))
      suffix=$(printf ' %3d.%d%% %s %s/s' "${pct_whole}" "${pct_frac}" "$(_human_size "${received}")" "$(_human_speed "${speed}")")
    else
      suffix=$(printf ' %s %s/s' "$(_human_size "${received}")" "$(_human_speed "${speed}")")
    fi
    local bar_width=$(( ${COLUMNS:-80} - ${#suffix} - 3 ))
    [[ "${bar_width}" -lt 10 ]] && bar_width=10
    local filled=0
    if [[ "${total}" -gt 0 ]]; then
      filled=$(( received * bar_width / total ))
      [[ "${filled}" -gt "${bar_width}" ]] && filled="${bar_width}"
    fi
    local empty=$(( bar_width - filled ))
    local bar_str=''
    local idx=0
    while [[ "${idx}" -lt "${filled}" ]]; do
      bar_str="${bar_str}#"
      (( idx++ ))
    done
    if [[ "${empty}" -gt 0 && "${filled}" -lt "${bar_width}" ]]; then
      bar_str="${bar_str}>"
      idx=1
      while [[ "${idx}" -lt "${empty}" ]]; do
        bar_str="${bar_str} "
        (( idx++ ))
      done
    fi
    printf '\r[%s]%s' "${bar_str}" "${suffix}" >&2
  else
    # Stats mode: curl-style table
    if [[ -z "${_progress_header_shown}" ]]; then
      # shellcheck disable=SC2059  # PROGRESS_FMT is readonly
      printf "${PROGRESS_FMT}"'\n' \
        '%' 'Total' '%' 'Recvd' 'Average' 'Time' 'Time' 'Time' 'Current' >&2
      # shellcheck disable=SC2059  # PROGRESS_FMT is readonly
      printf "${PROGRESS_FMT}"'\n' \
        '' '' '' '' 'Dload' 'Total' 'Spent' 'Left' 'Speed' >&2
      _progress_header_shown=1
    fi
    # Current speed: update baseline each time a new second has elapsed.
    if [[ "${elapsed}" -gt "${_cur_speed_elapsed}" ]]; then
      local dt=$(( elapsed - _cur_speed_elapsed ))
      _cur_speed=$(( (received - _cur_speed_received) / dt ))
      _cur_speed_received="${received}"
      _cur_speed_elapsed="${elapsed}"
    fi
    local time_total=-1 time_left=-1
    if [[ "${total}" -gt 0 ]]; then
      local pct=$(( received * 100 / total ))
      if [[ "${speed}" -gt 0 ]]; then
        time_total=$(( total / speed ))
        if [[ "${received}" -lt "${total}" ]]; then
          time_left=$(( (total - received) / speed ))
        else
          time_left=-1
        fi
      fi
      # shellcheck disable=SC2059  # PROGRESS_FMT is readonly
      printf '\r'"${PROGRESS_FMT}" \
        "${pct}" "$(_human_size "${total}")" \
        "${pct}" "$(_human_size "${received}")" \
        "$(_human_speed "${speed}")" \
        "$(_format_time "${time_total}")" \
        "$(_format_time "${elapsed}")" \
        "$(_format_time "${time_left}")" \
        "$(_human_speed "${_cur_speed}")" >&2
    else
      # shellcheck disable=SC2059  # PROGRESS_FMT is readonly
      printf '\r'"${PROGRESS_FMT}" \
        0 0 0 0 0 \
        "$(_format_time -1)" \
        "$(_format_time "${elapsed}")" \
        "$(_format_time -1)" \
        "$(_human_speed "${_cur_speed}")" >&2
    fi
  fi
}

_progress_finish() {
  [[ -z "${_progress_mode}" ]] && return
  local received="$1" total="$2"
  _progress_update "${received}" "${total}"
  printf '\n' >&2
}

# -- URL parsing --
parse_url() {
  local raw_url="$1"
  # Host is either an IPv6 literal in brackets (\[[^\]]+\]) or a plain
  # hostname / IPv4 address.  The two alternatives are group 3 (outer),
  # which shifts port to group 7 and path to group 8.
  local url_re='^((https?)://)?((\[[^]]+\])|([A-Za-z0-9._~%-]+))(:([0-9]+))?(/[^#]*)?(#.*)?$'
  if _regex "${raw_url}" "${url_re}"; then
    url_scheme="${_regex_groups[2]:-http}"
    url_host="${_regex_groups[3]}"   # includes brackets for IPv6, e.g. [::1]
    url_port="${_regex_groups[7]}"
    url_path="${_regex_groups[8]:-/}"
  else
    die "Malformed URL: ${raw_url}"
  fi
  [[ -z "${url_host}" ]] && die "No host in URL: ${raw_url}"
  [[ -z "${url_port}" ]] && { [[ "${url_scheme}" == "https" ]] && url_port=443 || url_port=80; }
  # Strip brackets to get the bare address for TCP connect calls.
  url_host_addr="${url_host#\[}"
  url_host_addr="${url_host_addr%\]}"
}

# Emit :PORT only for non-default ports (used in Host header and URL reconstruction).
port_suffix() {
  if [[ ("${url_scheme}" == "http"  && "${url_port}" != "80") ||
        ("${url_scheme}" == "https" && "${url_port}" != "443") ]]; then
    printf ':%s' "${url_port}"
  fi
}

# Resolve a Location value (possibly relative) against the current URL.
resolve_url() {
  local location="$1"
  case "${location}" in
    http://*|https://*) printf '%s' "${location}" ;;
    //*) printf '%s:%s' "${url_scheme}" "${location}" ;;
    /*)  printf '%s://%s%s%s' "${url_scheme}" "${url_host}" "$(port_suffix)" "${location}" ;;
    *)
      local url_dir="${url_path%/*}"
      printf '%s://%s%s%s/%s' "${url_scheme}" "${url_host}" "$(port_suffix)" "${url_dir%/}" "${location}" ;;
  esac
}

# -- Connection management --
open_connection() {
  if [[ "${url_scheme}" == "https" ]]; then
    _tls_connect "${url_host_addr}" "${url_port}"
  else
    _tcp_connect "${url_host_addr}" "${url_port}"
  fi
}

close_connection() {
  if [[ -n "${conn_is_tls}" && -n "${tls_pid}" ]]; then
    if [[ -n "${_IS_ZSH}" ]]; then
      { exec {conn_write_fd}>&-; } 2>/dev/null || true
      wait "${tls_pid}" 2>/dev/null || true
      { exec {conn_read_fd}<&-; } 2>/dev/null || true
    else
      { exec {conn_write_fd}>&-; } 2>/dev/null || true
      wait "${tls_pid}" 2>/dev/null || true
      { exec {conn_read_fd}<&-; } 2>/dev/null || true
    fi
    tls_pid=''
  elif [[ -n "${_IS_ZSH}" ]]; then
    if [[ -n "${conn_read_fd}" ]]; then { ztcp -c "${conn_read_fd}"; } 2>/dev/null || true; fi
  else
    if [[ "${conn_read_fd}" == "3" ]]; then { exec 3>&-; } 2>/dev/null || true; fi
  fi
  conn_read_fd=''
  conn_write_fd=''
  conn_is_tls=''
}

trap close_connection EXIT

# -- Request --
send_request() {
  local method="$1"
  # HTTP/1.0 avoids chunked transfer encoding; identity avoids compression.
  vlog "> ${method} ${url_path} HTTP/1.0"
  printf '%s %s HTTP/1.0\r\n' "${method}" "${url_path}" >&"${conn_write_fd}"

  local host_header
  host_header="${url_host}$(port_suffix)"
  printf 'Host: %s\r\n' "${host_header}" >&"${conn_write_fd}"
  vlog "> Host: ${host_header}"

  printf 'Accept-Encoding: identity\r\n' >&"${conn_write_fd}"
  vlog '> Accept-Encoding: identity'

  local user_agent="${opt_agent:-shurl/1.0}"
  printf 'User-Agent: %s\r\n' "${user_agent}" >&"${conn_write_fd}"
  vlog "> User-Agent: ${user_agent}"

  local header
  for header in "${opt_headers[@]}"; do
    printf '%s\r\n' "${header}" >&"${conn_write_fd}"
    vlog "> ${header}"
  done

  if [[ -n "${opt_auth}" ]]; then
    local encoded
    encoded=$(printf '%s' "${opt_auth}" | openssl enc -base64 -A 2>/dev/null) \
      || die "Failed to base64-encode credentials (openssl missing?)"
    printf 'Authorization: Basic %s\r\n' "${encoded}" >&"${conn_write_fd}"
    vlog '> Authorization: Basic ***'
  fi

  if [[ -n "${opt_referer}" ]]; then
    printf 'Referer: %s\r\n' "${opt_referer}" >&"${conn_write_fd}"
    vlog "> Referer: ${opt_referer}"
  fi

  if [[ -n "${opt_data}" && -z "${opt_head}" ]]; then
    local byte_len
    # ${#var} counts characters; LC_ALL=C in a subshell makes bash/zsh count bytes.
    byte_len=$(LC_ALL=C; echo "${#opt_data}")
    printf 'Content-Type: application/x-www-form-urlencoded\r\n' >&"${conn_write_fd}"
    printf 'Content-Length: %d\r\n' "${byte_len}" >&"${conn_write_fd}"
    vlog "> Content-Length: ${byte_len}"
  fi

  printf '\r\n' >&"${conn_write_fd}"
  [[ -n "${opt_data}" && -z "${opt_head}" ]] && printf '%s' "${opt_data}" >&"${conn_write_fd}"
}

# -- Response --
read_status_line() {
  local timeout_flag=()
  [[ -n "${opt_connect_timeout}" ]] && timeout_flag=(-t "${opt_connect_timeout}")

  local raw_line
  if ! IFS= read -r "${timeout_flag[@]}" -u "${conn_read_fd}" raw_line; then
    [[ -n "${opt_connect_timeout}" ]] \
      && die "Timed out waiting for response from ${url_host}"
    [[ -n "${conn_is_tls}" ]] \
      && die "TLS handshake failed or ${url_host} is not an HTTPS server"
    die "Connection closed before status line received"
  fi
  local status_line="${raw_line%$'\r'}"
  vlog "< ${status_line}"
  [[ -n "${opt_head}" ]] && printf '%s\n' "${status_line}"

  local status_re='^HTTP/([0-9.]+) +([0-9]+) *(.*)$'
  if _regex "${status_line}" "${status_re}"; then
    resp_code="${_regex_groups[2]}"
    resp_msg="${_regex_groups[3]}"
  else
    die "Malformed HTTP status line: ${status_line}"
  fi
}

read_response_headers() {
  resp_location=''
  resp_content_length=''
  local dump_fd=''
  if [[ -n "${opt_dump_headers}" ]]; then
    _open_write_fd "${opt_dump_headers}" \
      || die "Cannot open ${opt_dump_headers} for writing"
    dump_fd="${_DUMP_FD}"
  fi

  local raw_line header_line header_name
  local header_re='^([A-Za-z0-9-]+): *(.*)$'
  while IFS= read -r -u "${conn_read_fd}" raw_line; do
    header_line="${raw_line%$'\r'}"
    [[ -z "${header_line}" ]] && break
    vlog "< ${header_line}"
    [[ -n "${dump_fd}" ]] && printf '%s\n' "${header_line}" >&"${dump_fd}"
    [[ -n "${opt_head}" ]] && printf '%s\n' "${header_line}"
    if _regex "${header_line}" "${header_re}"; then
      header_name="$(_tolower "${_regex_groups[1]}")"
      [[ "${header_name}" == "location" ]] && resp_location="${_regex_groups[2]}"
      [[ "${header_name}" == "content-length" ]] && resp_content_length="${_regex_groups[2]}"
    fi
  done

  [[ -n "${dump_fd}" ]] && _close_write_fd
}

# -- Body FD splicers (shell read drops null bytes) --

# Returns 0 if splicer NAME is usable (bashcat variants always are).
_splicer_available() {
  case "$1" in
    cat) command -v cat &>/dev/null ;;
    openssl) command -v openssl &>/dev/null && printf '' | openssl enc -none &>/dev/null ;;
    bashcat|bashcat-force) ;;
  esac
}

_resolve_splicer() {
  local c
  if [[ -n "${opt_splicer}" ]]; then
    _splicer_available "${opt_splicer}" || die "splicer ${opt_splicer} is not available"
    _SPLICER="${opt_splicer}"
  else
    for c in cat openssl bashcat; do
      if _splicer_available "${c}"; then _SPLICER="${c}"; break; fi
    done
  fi
  vlog "Using splicer: ${_SPLICER}"
}

# _bashcat CONTENT_LENGTH [FORCE] - read binary from stdin, write to stdout.
# Restores NUL bytes stripped by read -d when CONTENT_LENGTH is known.
# FORCE=1 (bashcat-force): read until EOF without Content-Length (no NUL restore).
if [[ -n "${_IS_ZSH}" ]]; then
  _bashcat() {
    local content_length="$1" force="${2:-0}" byte_count=0 line
    [[ -z "${content_length}" && "${force}" -eq 0 ]] \
      && die "bashcat requires Content-Length (use --shurl-splicer bashcat-force to override)"
    LC_CTYPE=C
    while IFS= read -r -d $'\0' line || [[ -n "${line}" ]]; do
      print -nr -- "${line}"
      (( byte_count += ${#line} ))
      if [[ -n "${content_length}" ]] && (( byte_count < content_length )); then
        print -nr -- $'\0'
        (( byte_count++ ))
      fi
    done
  }
else
  _bashcat() {
    local content_length="$1" force="${2:-0}" byte_count=0
    [[ -z "${content_length}" && "${force}" -eq 0 ]] \
      && die "bashcat requires Content-Length (use --shurl-splicer bashcat-force to override)"
    LC_CTYPE=C
    local line
    while IFS= read -r -d '' line || [[ -n "${line}" ]]; do
      printf '%s' "${line}"
      ((byte_count+=${#line}))
      if [[ -n "${content_length}" ]] && ((byte_count < content_length)); then
        printf '\0'
        ((byte_count++))
      fi
    done
  }
fi

# _splice_from_fd SRC_FD [DEST_FILE] [BACKGROUND=0]
# Splices bytes from SRC_FD to DEST_FILE or stdout. When BACKGROUND=1, runs in &.
_splice_from_fd() {
  local src_fd="$1" dest="${2:-}" force=0
  [[ "${_SPLICER}" == bashcat-force ]] && force=1

  case "${_SPLICER}" in
    cat)                   local -a _cmd=(cat) ;;
    openssl)               local -a _cmd=(openssl enc -none) ;;
    bashcat|bashcat-force) local -a _cmd=(_bashcat "${resp_content_length}" "${force}") ;;
  esac

  if [[ -n "${dest}" ]]; then
    "${_cmd[@]}" <&"${src_fd}" > "${dest}"
  else
    "${_cmd[@]}" <&"${src_fd}"
  fi
}

# -- Body transfer with optional progress --
# read with timeout from /dev/tty (progress requires a TTY anyway).
_tty_sleep() { read -r -t 0.1 _ < /dev/tty 2>/dev/null || true; }

transfer_body() {
  if [[ -z "${_progress_mode}" ]]; then
    if [[ -n "${opt_output}" ]]; then
      _splice_from_fd "${conn_read_fd}" "${opt_output}" \
        || die "Failed to write body to ${opt_output}"
    else
      _splice_from_fd "${conn_read_fd}" || die "Failed to write body"
    fi
    return
  fi

  local total="${resp_content_length:-0}"

  _splice_from_fd "${conn_read_fd}" "${opt_output}" &
  local splicer_pid=$!

  local received=0
  while kill -0 "${splicer_pid}" 2>/dev/null; do
    if [[ -n "${_IS_ZSH}" ]]; then
      received=$(_file_size "${opt_output}")
    else
      received=$(_file_size "${splicer_pid}")
    fi
    _progress_update "${received}" "${total}"
    _tty_sleep
  done
  wait "${splicer_pid}" || die "Failed to write body to ${opt_output}"

  [[ "${total}" -gt 0 ]] && received="${total}"
  _progress_finish "${received}" "${total}"
}

# -- Main loop --
parse_url "${url}"
_resolve_splicer
redirs_left="${opt_max_redirs}"
[[ -n "${_progress_mode}" ]] && _progress_start

while true; do
  open_connection
  send_request "${method}"
  read_status_line
  read_response_headers

  if [[ "${resp_code}" -ge 200 && "${resp_code}" -lt 300 ]]; then
    [[ -z "${opt_head}" ]] && transfer_body
    close_connection
    exit 0

  elif [[ "${resp_code}" -ge 300 && "${resp_code}" -lt 400 ]]; then
    [[ -z "${opt_follow}" ]]    && die "HTTP ${resp_code} ${resp_msg} (use -L to follow redirects)"
    [[ -z "${resp_location}" ]] && die "HTTP ${resp_code} with no Location header"
    [[ "${redirs_left}" -le 0 ]] && die "Too many redirects (--max-redirs ${opt_max_redirs})"
    (( redirs_left-- )) || true
    new_url=$(resolve_url "${resp_location}")
    if [[ -n "${_progress_mode}" ]]; then
      _progress_update 0 0
      printf '\n' >&2
    else
      log "Redirect [${resp_code}] -> ${new_url}"
    fi
    close_connection
    url="${new_url}"
    parse_url "${url}"
    # 301/302/303: downgrade to GET and drop body (curl behaviour). 307/308: preserve method.
    case "${resp_code}" in 301|302|303) method="GET"; opt_data='' ;; esac
    continue

  else
    die "HTTP ${resp_code} ${resp_msg}"
  fi
done
